# Copy this file to .env and fill in real values before running Docker

JWT_SECRET=-change-this-jwt-secret-in-production-min-256-bits
JWT_EXPIRATION=86400000

ENCRYPTION_SECRET=:-change-this-encryption-key-in-production

PLAID_CLIENT_ID=-change-this-plaid-client-id-in-production
PLAID_SECRET=-change-this-plaid-secret-in-production
PLAID_ENVIRONMENT=sandbox
